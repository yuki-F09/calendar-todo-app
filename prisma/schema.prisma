// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id           Int     @id @default(autoincrement())
  title        String
  description  String?
  role_over    Boolean @default(false)
  auth_id      String
  isCompleted  Boolean @default(false)
  date         String
  tags         Tag[]
}

enum TagColor {
  BLUE
  PURPLE
  GREEN
  ORANGE
  RED
  LIGHT_BLUE
  LIGHT_PURPLE
  LIGHT_GREEN
  LIGHT_ORANGE
  LIGHT_RED
}

model Tag {
  id       Int      @id @default(autoincrement())
  color    TagColor
  tag_name String
  auth_id  String
  tasks    Task[]
}

enum RegularType {
  daily
  weekly
  monthly
  yearly
}

model TagSetting{
  id Int @id @default(autoincrement())
  regular_type RegularType
  auth_id String
  tag_id Int
}
